(doc FuzzHarness "Reusable helpers for deterministic state-machine fuzzing.")
(defmodule FuzzHarness
  (doc getenv-int "Read an integer env var with fallback and minimum clamp.")
  (defn getenv-int [name default min]
    (match (IO.getenv name)
      (Maybe.Nothing) default
      (Maybe.Just raw)
        (match (Int.from-string &raw)
          (Maybe.Just value)
            (if (< value min) min value)
          (Maybe.Nothing) default)))

  (doc getenv-int-bounded "Read an integer env var with fallback and [min,max] clamp.")
  (defn getenv-int-bounded [name default min max]
    (let [value (getenv-int name default min)]
      (if (> value max) max value)))

  (doc getenv-double "Read a double env var with fallback.")
  (defn getenv-double [name default]
    (match (IO.getenv name)
      (Maybe.Nothing) default
      (Maybe.Just raw)
        (match (Double.from-string &raw)
          (Maybe.Just value) value
          (Maybe.Nothing) default)))

  (doc getenv-bool "Read a bool env var with fallback. Accepts 1/0 and true/false/yes/no.")
  (defn getenv-bool [name default]
    (match (IO.getenv name)
      (Maybe.Nothing) default
      (Maybe.Just raw)
        (if (or (String.= &raw "1") (String.= &raw "true") (String.= &raw "yes"))
          true
          (if (or (String.= &raw "0") (String.= &raw "false") (String.= &raw "no"))
            false
            default))))

  (doc configure-build "Configure optimization and sanitizer flags for rc tests.

Environment variables:
- `RC_OPT_LEVEL`: `O0|O1|O2|O3` (or with leading `-`), default `-O1`
- `RC_SANITIZE`: `1|true|yes` enables ASan+UBSan, default `true`")
  (defn configure-build []
    (let [sanitize? (getenv-bool "RC_SANITIZE" true)]
      (do
        (match (IO.getenv "RC_OPT_LEVEL")
          (Maybe.Nothing)
            (Project.append-cflag "-O1")
          (Maybe.Just raw)
            (if (or (String.= &raw "O0") (String.= &raw "-O0"))
              (Project.append-cflag "-O0")
              (if (or (String.= &raw "O1") (String.= &raw "-O1"))
                (Project.append-cflag "-O1")
                (if (or (String.= &raw "O2") (String.= &raw "-O2"))
                  (Project.append-cflag "-O2")
                  (if (or (String.= &raw "O3") (String.= &raw "-O3"))
                    (Project.append-cflag "-O3")
                    (Project.append-cflag "-O1"))))))
        (Project.append-cflag "-fno-omit-frame-pointer")
        (if sanitize?
          (do
            (Project.append-cflag "-fsanitize=address -Wno-macro-redefined")
            (Project.append-cflag "-fsanitize=undefined")
            (Project.append-cflag "-fno-sanitize-recover=all"))
          ()))))

  (doc run-once "Run one seeded fuzz execution for `steps`, calling `tick-fn` each step.")
  (defn run-once [seed steps tick-fn]
    (do
      (Random.seed-from seed)
      (let-do [executed 0]
        (for [i 0 steps]
          (do
            (ignore i)
            (~tick-fn)
            (set! executed (Int.inc executed))))
        executed)))

  (doc run-suite "Run multiple fuzz executions with deterministic seed progression.")
  (defn run-suite [runs steps base-seed seed-stride run-once-fn]
    (let-do [total 0]
      (for [run 0 runs]
        (let [seed (+ base-seed (* seed-stride (Double.from-int run)))
              executed (~run-once-fn seed steps)]
          (set! total (+ total executed))))
      total))
)
